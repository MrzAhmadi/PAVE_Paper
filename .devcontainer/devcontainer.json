{
    "name": "LaTeX Environment",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "James-Yu.latex-workshop"
            ],
            "settings": {
                "latex-workshop.view.pdf.viewer": "tab",
                "latex-workshop.latex.autoBuild.run": "onSave"
            }
        }
    }
}